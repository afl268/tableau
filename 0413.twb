      <aliases enabled='yes' />
      <column caption='Sales + Profit' datatype='real' name='[Calculation_628815121199099904]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Sales]) + SUM([Profit])' />
      </column>
      <column caption='Profit Ratio' datatype='real' name='[Calculation_628815121199927297]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit]) / SUM([Sales])' />
      </column>
      <column caption='계산1' datatype='integer' name='[Calculation_628815121224773635]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INDEX()'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='계산2' datatype='real' name='[Calculation_628815121246793733]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RUNNING_AVG(SUM([Profit]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='high / low sales' datatype='string' name='[Calculation_628815121250291719]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Sales]) &gt;= 100000 THEN &apos;High&apos; ELSE &apos;Low&apos; END' />
      </column>
      <column caption='High / Low Sales' datatype='string' name='[Calculation_628815121250570248]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Sales]) &gt;= 100000 THEN &apos;High&apos; END' />
      </column>
      <column caption='hIGH / lOW sALES' datatype='string' name='[Calculation_628815121255211017]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IIF(SUM([Sales]) &gt;= 100000, &apos;High&apos;, &apos;Low&apos;)' />
      </column>
