      <aliases enabled='yes' />
      <column caption='Sales on November 2020' datatype='real' name='[Calculation_676665866588758016]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IIF(([Order Date] &gt;= DATE(&apos;2022-11-01&apos;)) AND &#13;&#10;([Order Date] &lt;= DATE(&apos;2022-11-30&apos;)), &#13;&#10;[Sales],&#13;&#10;NULL)' />
      </column>
      <column caption='Sales for Technology' datatype='real' name='[Calculation_676665866593443841]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IIF([Category] = &apos;Technology&apos;, [Sales], NULL)' />
      </column>
